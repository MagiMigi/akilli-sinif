    {
        "id": "process-status",
        "type": "function",
        "z": "akilli-sinif-flow",
        "name": "Process Status",
        "func": "var parts = msg.topic.split('/');\nvar classroomId = parts[1];\n\n// Cihaz durumunu global'e kaydet\nvar deviceStatus = {\n    status: msg.payload.status,\n    device: msg.payload.device,\n    ip: msg.payload.ip,\n    rssi: msg.payload.rssi,\n    uptime: msg.payload.uptime,\n    lastSeen: new Date().toISOString()\n};\n\nglobal.set('device_' + classroomId, deviceStatus);\n\n// InfluxDB'ye kaydet\nmsg.payload = [\n    {\n        measurement: \"device_status\",\n        tags: {\n            classroom: classroomId,\n            device: msg.payload.device || 'unknown'\n        },\n        fields: {\n            online: msg.payload.status === 'online' ? 1 : 0,\n            rssi: msg.payload.rssi || 0,\n            uptime: msg.payload.uptime || 0\n        }\n    }\n];\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
        "y": 580,
        "wires": [
            [
                "influxdb-write"
            ]
        ]
