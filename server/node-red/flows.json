    {
        "id": "process-temperature",
        "type": "function",
        "z": "akilli-sinif-flow",
        "name": "Process Temperature",
        "func": "// Topic'ten sınıf ID'sini çıkar\nvar parts = msg.topic.split('/');\nvar classroomId = parts[1];\n\n// InfluxDB için veriyi hazırla\nmsg.payload = [\n    {\n        measurement: \"temperature\",\n        tags: {\n            classroom: classroomId,\n            sensor: \"temperature\",\n            unit: \"C\"\n        },\n        fields: {\n            value: msg.payload.value\n        }\n    }\n];\n\n// Global değişkene kaydet (dashboard için)\nglobal.set('temp_' + classroomId, msg.payload[0].fields.value);\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
        "y": 160,
        "wires": [
            [
                "influxdb-write"
            ]
        ]
    },
