    {
        "id": "mqtt-sensors-all",
        "type": "mqtt in",
        "z": "akilli-sinif-flow",
        "name": "Tüm Sensörler",
        "topic": "akilli-sinif/+/sensors/#",
        "qos": "0",
        "datatype": "json",
        "broker": "mqtt-broker-config",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 110,
        "y": 1040,
        "wires": [
            [
                "automation-logic"
            ]
        ]
    },
    {
        "id": "automation-logic",
        "type": "function",
        "z": "akilli-sinif-flow",
        "name": "Otomasyon Mantığı",
        "func": "// Topic'i parse et\nvar parts = msg.topic.split('/');\nvar classroomId = parts[1];\nvar sensorType = parts[3];\n\n// Global değerlerden mevcut durumu al\nvar temp = global.get('temp_' + classroomId) || 24;\nvar light = global.get('light_' + classroomId) || 300;\nvar motion = global.get('motion_' + classroomId) || 0;\nvar windowState = global.get('window_' + classroomId) || 0;\nvar airQuality = global.get('air_' + classroomId) || 100;\n\n// Mevcut aktüatör durumları\nvar currentLed = global.get('led_' + classroomId) || 0;\nvar currentFan = global.get('fan_' + classroomId) || 0;\n\n// Otomasyon kuralları\nvar commands = [];\n\n// Kural 1: Hareket yoksa ve 5 dakika geçtiyse ışıkları kapat\nif (motion === 0) {\n    var lastMotion = global.get('lastMotion_' + classroomId) || 0;\n    var now = Date.now();\n    if (now - lastMotion > 300000 && currentLed > 0) { // 5 dakika\n        commands.push({\n            topic: 'akilli-sinif/' + classroomId + '/control/led',\n            payload: { state: 'off' },\n            reason: 'Hareket yok, 5 dakika gecti'\n        });\n    }\n} else {\n    global.set('lastMotion_' + classroomId, Date.now());\n}\n\n// Kural 2: Hareket var ve ortam karanlıksa ışıkları aç\nif (motion === 1 && light < 200 && currentLed === 0) {\n    commands.push({\n        topic: 'akilli-sinif/' + classroomId + '/control/led',\n        payload: { brightness: 80 },\n        reason: 'Hareket var ve ortam karanlik'\n    });\n}\n\n// Kural 3: Sıcaklık yüksek ve pencere kapalıysa fan aç\nif (temp > 26 && windowState === 0 && currentFan === 0) {\n    commands.push({\n        topic: 'akilli-sinif/' + classroomId + '/control/fan',\n        payload: { speed: 50 },\n        reason: 'Sicaklik yuksek (' + temp + 'C)'\n    });\n}\n\n// Kural 4: Sıcaklık normale döndüyse fanı kapat\nif (temp < 24 && currentFan > 0) {\n    commands.push({\n        topic: 'akilli-sinif/' + classroomId + '/control/fan',\n        payload: { state: 'off' },\n        reason: 'Sicaklik normale dondu (' + temp + 'C)'\n    });\n}\n\n// Kural 5: Hava kalitesi kötüyse fan aç (pencere kapalıysa)\nif (airQuality > 200 && windowState === 0 && currentFan < 50) {\n    commands.push({\n        topic: 'akilli-sinif/' + classroomId + '/control/fan',\n        payload: { speed: 75 },\n        reason: 'Hava kalitesi kotu (' + airQuality + ' ppm)'\n    });\n}\n\n// Komutları gönder\nif (commands.length > 0) {\n    // Her komut için ayrı mesaj\n    return commands.map(function(cmd) {\n        node.warn('Otomasyon: ' + cmd.reason);\n        return {\n            topic: cmd.topic,\n            payload: cmd.payload\n        };\n    });\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 330,
        "y": 1040,
        "wires": [
            [
                "mqtt-automation-out"
            ]
        ]
