    {
        "id": "process-status",
        "type": "function",
        "z": "akilli-sinif-flow",
        "name": "Status Format",
        "func": "var parts = msg.topic.split('/');\nvar classroomId = parts[1];\n\nmsg.measurement = \"device_status\";\nmsg.payload = {\n    classroom: classroomId,\n    device: msg.payload.device || \"unknown\",\n    online: msg.payload.status === \"online\" ? 1 : 0,\n    rssi: msg.payload.rssi || 0,\n    uptime: msg.payload.uptime || 0\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 360,
        "y": 200,
        "wires": [
            [
                "influxdb-write"
            ]
        ]
    },
