# Akıllı Sınıf - Git Ignore
# Hassas bilgileri ve gereksiz dosyaları git'ten hariç tut

# ============================================
# GÜVENLİK - Asla commit'leme
# ============================================
*.env
.env.*
credentials.*
secrets.*
*.key
*.pem
wifi_config.json

# ============================================
# ARDUINO / ESP32 BUILD ÇIKTILARI
# ============================================
*.bin
*.elf
*.map
*.hex
build/
.arduino15/

# ============================================
# AI MODEL AĞIRLIKLARI (büyük dosyalar)
# ============================================
*.pt
*.onnx
*.weights
*.pb

# ============================================
# AI İŞLEME - Dinamik veriler
# ============================================
server/ai-processing/captured_images/
server/ai-processing/venv/
server/ai-processing/__pycache__/

# ============================================
# NODE.JS
# ============================================
node_modules/

# ============================================
# PYTHON
# ============================================
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# ============================================
# IDE
# ============================================
.vscode/
.idea/
*.swp
*.swo

# ============================================
# İŞLETİM SİSTEMİ
# ============================================
.DS_Store
Thumbs.db

# ============================================
# LOGLAR VE GEÇİCİ DOSYALAR
# ============================================
*.log
logs/
*.tmp
*.temp
dist/
