/*
 * Akilli Sinif - Firmware Secrets Template
 * ========================================
 *
 * KULLANIM:
 *   1. Bu dosyayi `secrets.h` olarak kopyala (ayni dizinde):
 *        cp secrets.h.example secrets.h
 *   2. Asagidaki degerleri KENDI mosquitto kullanici/sifre'nle degistir.
 *   3. `secrets.h` .gitignore tarafindan repo'dan haric tutulmustur —
 *      ASLA commit etme. (secrets.* kurali var, secrets.h.example ise
 *      `!secrets.*.example` istisnasiyla repoda kalir.)
 *
 * MOSQUITTO TARAFI:
 *   sudo mosquitto_passwd -c /etc/mosquitto/passwd <MQTT_USER>
 *   # Sifre olarak <MQTT_PASSWORD> degerini gir.
 */

#pragma once

#define MQTT_USER_DEFAULT      "esp32"
#define MQTT_PASSWORD_DEFAULT  "CHANGE_ME"
